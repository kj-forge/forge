# ─────────────────────────────────────────────────────────────────────────────
# Forge — environment variables
# Copy this file to `.env` (gitignored) and fill in the real values.
# ─────────────────────────────────────────────────────────────────────────────

# Database — Neon Postgres (https://console.neon.tech)
# Use the "pooled" connection string from the Connection Details panel.
# For local dev, point to the `dev` branch of the Neon project `forge`.
# For migration runs against prod, swap to the `main` branch connection string.
DATABASE_URL="postgresql://user:password@host.neon.tech/forge?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# Seed — optional overrides for `bun run db:seed`
# ─────────────────────────────────────────────────────────────────────────────
# The seed inserts a "demo athlete" with safe placeholder defaults. To seed
# under your own identity instead, uncomment and fill these in:
# SEED_DEMO_EMAIL="you@example.com"
# SEED_DEMO_NAME="Your Name"
# SEED_DEMO_USERNAME="your-handle"
