# ─────────────────────────────────────────────────────────────────────────────
# Forge — environment variables
# Copy this file to `.env` (gitignored) and fill in the real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Neon Postgres connection string. Use the DIRECT (non-pooled) URL for the
# dev branch when running locally — drizzle-kit migrate and bun dev both use
# this. Get it from https://console.neon.tech → forge → dev branch →
# Connection details → uncheck "Connection pooling".
DATABASE_URL="postgresql://user:password@host.neon.tech/forge?sslmode=require"

# ── Seed (optional) ─────────────────────────────────────────────────────────
# Override the demo athlete's identity inserted by `bun run db:seed`.
# Defaults: demo@forge.local / Demo Athlete / demo-athlete.
# SEED_DEMO_EMAIL="you@example.com"
# SEED_DEMO_NAME="Your Name"
# SEED_DEMO_USERNAME="your-handle"

# ── Better Auth ─────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Generate locally:
#   openssl rand -base64 32
# NEVER share or commit. Rotating this logs everyone out, so save it once
# generated. 32+ chars required.
BETTER_AUTH_SECRET=""

# Base URL of this app — single source of truth for server AND client.
# Server reads via `env.VITE_APP_URL` (from process.env); Vite inlines
# VITE_* vars into the client bundle, so the auth client reads it via
# `import.meta.env.VITE_APP_URL`. Same value, two namespaces.
# Critical: must match Google OAuth's authorized redirect URI prefix.
# Dev = http://localhost:3000; prod = your real domain.
VITE_APP_URL="http://localhost:3000"

# ── Resend ──────────────────────────────────────────────────────────────────
# API key for sending magic-link emails. Get from
# https://resend.com/api-keys (sign up first if needed).
# Free tier: 3000 emails/month, 100/day — more than enough for Forge dev
# and early production.
RESEND_API_KEY=""

# "From" address that magic-link emails are sent from.
# - In Resend dev mode, you can use `onboarding@resend.dev` (Resend's shared
#   sender; only delivers to the email you signed up with — perfect for dev).
# - For production, verify your own domain in Resend and use e.g.
#   `noreply@forge.app`. Without a verified domain, emails won't deliver.
RESEND_FROM_EMAIL="onboarding@resend.dev"

# ── Google OAuth ────────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com → APIs & Services →
# Credentials → Create credentials → OAuth client ID → Application type:
# "Web application".
#
# Authorized redirect URIs (must match exactly):
#   http://localhost:3000/api/auth/callback/google     (dev)
#   https://forge.app/api/auth/callback/google         (prod placeholder)
#
# The dev URI must use http (not https) for localhost — Google allows this
# specifically for localhost. Production must always be https.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Production deploy notes ─────────────────────────────────────────────────
# In production these values live in:
#   - Workers Secrets (injected as bindings at runtime) — set via
#     `wrangler secret put <name>` locally, or automatically synced from
#     GitHub repo secrets by the deploy workflow on push to main.
#   - GitHub repo secrets (Settings → Secrets and variables → Actions),
#     consumed by .github/workflows/deploy.yml.
# Use a SEPARATE Neon branch for prod (not the dev one). Generate a fresh
# BETTER_AUTH_SECRET — do not reuse the dev value.
#
# For local Workers parity testing (`bun run preview` = `wrangler dev`),
# put the same values into a gitignored `.dev.vars` file at the repo root
# in `KEY=value` format. The Cloudflare Vite plugin reads `.dev.vars`
# during `wrangler dev`; `bun dev` (vite) reads `.env` as usual.
