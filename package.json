{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Forge — hybrid strength training PWA. Local-first with Postgres + Electric SQL, AI coach (Claude). Forged daily.",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite start",
    "typecheck": "tsc --noEmit",
    "format": "bunx --bun biome check --write .",
    "lint": "bunx --bun biome check",
    "knip": "bunx knip",
    "check": "bun run lint && bun run typecheck && bun run knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
