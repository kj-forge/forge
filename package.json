{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Forge — Hyrox athlete journal PWA with rehab tracking, daily wellness, and AI-driven weekly summaries. Local-first via Postgres + Electric SQL. Forged daily.",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite start",
    "preview": "wrangler dev",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "format": "bunx --bun biome check --write .",
    "lint": "bunx --bun biome check",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "knip": "bunx knip",
    "check": "bun run lint && bun run typecheck && bun run test && bun run knip",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:seed": "bun run db/seed.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "better-auth": "^1.6.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.78.0",
    "react-number-format": "^5.4.5",
    "resend": "^6.12.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@cloudflare/vite-plugin": "^1.40.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@happy-dom/global-registrator": "^20.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.98.0",
    "ws": "^8.21.0"
  }
}
